# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection URL (from your Neon project dashboard)
# Format: postgres://user:password@host/database?sslmode=require
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Must be at least 32 characters. Use a strong random value in production.
JWT_KEY=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_ISSUER=DivanSufi
JWT_AUDIENCE=DivanSufiUsers

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ── ASP.NET Core ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:10000
